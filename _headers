## Askerî Terimler Sözlüğü — güvenlik başlıkları
## Statik dosyalar için genel kural.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  X-Robots-Tag: index, follow
  ## Ana sayfada gömülü <script> bulunduğundan script-src burada 'unsafe-inline'
  ## kabul eder. Daha güçlü koruma için o betiği harici bir .js dosyasına taşıyıp
  ## bu satırdan 'unsafe-inline' kaldırılabilir (aşağıdaki nota bakınız).
  Content-Security-Policy: default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; upgrade-insecure-requests

/404.html
  X-Robots-Tag: noindex, nofollow

/.env
  X-Robots-Tag: noindex, nofollow

/env
  X-Robots-Tag: noindex, nofollow
